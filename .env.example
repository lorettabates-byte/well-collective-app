# URL of the deployed well-collective-server backend
VITE_PUSH_API_URL=http://localhost:4000

# Same public key generated by `npm run generate-vapid-keys` in well-collective-server
VITE_VAPID_PUBLIC_KEY=

# Must match ADMIN_API_KEY on the backend. Only used on the admin content
# upload page — keep this app private since this key is visible in the
# built frontend bundle.
VITE_ADMIN_API_KEY=
